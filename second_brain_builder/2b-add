# filename: second_brain_builder/2b-add
# purpose: CLI command: 2b-add "your thought here" — adds thought instantly (same logic as web save) and prints AI reply. Run with: ./2b-add "thought text"

#!/usr/bin/env python3
import sys
import argparse
from pathlib import Path
import os

# Ensure we can import the modules
script_dir = Path(__file__).parent.resolve()
os.chdir(script_dir)
sys.path.insert(0, str(script_dir))

from src.modules.thought_processor import save_thought_and_reply

def main():
    parser = argparse.ArgumentParser(description="Add a thought to your Second Brain")
    parser.add_argument("thought", nargs="*", help="The thought text (wrap in quotes if it contains spaces)")
    args = parser.parse_args()

    if not args.thought:
        print("Usage: ./2b-add \"your thought here\"")
        print("Example: ./2b-add \"this is to show how a CLI command would look for getting a thought into the brain\"")
        sys.exit(1)

    thought_text = " ".join(args.thought)

    print(f"🧠 Adding thought: {thought_text[:80]}{'...' if len(thought_text) > 80 else ''}")
    result = save_thought_and_reply(thought_text)

    if result.get("success"):
        print("✅ Saved successfully!")
        print(f"🤖 2nd Brain Reply:\n{result.get('reply', 'No reply received')}")
    else:
        print("❌ Failed to save thought")
        print(result.get("reply", "Unknown error"))

if __name__ == "__main__":
    main()
